{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": ["AGENTS.md"],
  "formatter": {
    "prettier": {
      "command": ["bun", "run", "format"]
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".turbo/**",
      ".next/**",
      "dist/**",
      ".git/**",
      "bun.lock",
      "coverage/**",
      "drizzle/**",
      "src-tauri/target/**",
      "**/*.map"
    ]
  },
  "plugin": []
}
